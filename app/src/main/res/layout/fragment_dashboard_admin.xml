<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="80dp">

            <!-- Blue Header Background -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@drawable/bg_header_dashboard"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Header Content -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:alpha="0.7"
                android:text="SOLO LIBROS · NO HERRAMIENTAS"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivNotifications"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_header_badge"
                android:padding="6dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:layout_constraintEnd_toStartOf="@+id/ivDarkMode"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/ivDarkMode"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_header_badge"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_month"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="Biblioteca"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Préstamo de Libros"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="italic"
                app:layout_constraintStart_toStartOf="@id/tvTitle"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <TextView
                android:id="@+id/badgeAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_header_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Panel de Administrador"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvTitle"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:alpha="0.8"
                android:drawablePadding="4dp"
                android:text="Abril 2026"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
                app:drawableTint="@color/white"
                app:layout_constraintBottom_toBottomOf="@id/badgeAdmin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/badgeAdmin" />

            <!-- Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/headerBackground"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivSummaryIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_pill_gray"
                        android:padding="12dp"
                        android:src="@drawable/ic_book"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/header_blue" />

                    <TextView
                        android:id="@+id/tvSummaryLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Total préstamos activos hoy"
                        android:textColor="@color/blue_slate"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/ivSummaryIcon"
                        app:layout_constraintTop_toTopOf="@id/ivSummaryIcon" />

                    <TextView
                        android:id="@+id/tvTotalPrestamos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="@color/header_blue"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/tvSummaryLabel"
                        app:layout_constraintTop_toBottomOf="@id/tvSummaryLabel" />

                    <TextView
                        android:id="@+id/badgeSuccess"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_green"
                        android:drawablePadding="4dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="9 al día"
                        android:textColor="@color/success_green"
                        android:textSize="11sp"
                        app:drawableStartCompat="@android:drawable/checkbox_on_background"
                        app:drawableTint="@color/success_green"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/badgeError"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_pill_red"
                        android:drawablePadding="4dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="3 en mora"
                        android:textColor="@color/mora_red"
                        android:textSize="11sp"
                        app:drawableStartCompat="@android:drawable/stat_notify_error"
                        app:drawableTint="@color/mora_red"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/badgeSuccess" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section Pendientes -->
            <ImageView
                android:id="@+id/ivSectionMorosos"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/ic_book"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSummary"
                app:tint="@color/mora_red" />

            <TextView
                android:id="@+id/tvSectionTitleMorosos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Préstamos con retraso"
                android:textColor="@color/header_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivSectionMorosos"
                app:layout_constraintStart_toEndOf="@id/ivSectionMorosos"
                app:layout_constraintTop_toTopOf="@id/ivSectionMorosos" />

            <TextView
                android:id="@+id/badgeMorososCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_pill_red"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="3 pendientes"
                android:textColor="@color/mora_red"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@id/tvSectionTitleMorosos"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvSectionTitleMorosos" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMorosos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/tvSectionTitleMorosos"
                tools:itemCount="3"
                tools:listitem="@layout/item_prestamo_pendiente" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerTodosMorosos"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/mora_red_light"
                android:text="Ver todos los pendientes"
                android:textColor="@color/mora_red"
                app:cornerRadius="20dp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconGravity="textEnd"
                app:iconTint="@color/mora_red"
                app:layout_constraintTop_toBottomOf="@id/rvMorosos" />

            <!-- Section Libro Top -->
            <ImageView
                android:id="@+id/ivSectionTop"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:src="@android:drawable/btn_star_big_on"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnVerTodosMorosos"
                app:tint="@color/gold_yellow" />

            <TextView
                android:id="@+id/tvSectionTitleTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Libro más solicitado"
                android:textColor="@color/header_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivSectionTop"
                app:layout_constraintStart_toEndOf="@id/ivSectionTop"
                app:layout_constraintTop_toTopOf="@id/ivSectionTop" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTopLibro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
