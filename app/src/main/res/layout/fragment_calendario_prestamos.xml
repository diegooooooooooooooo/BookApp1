            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:textColor="@color/blue_slate"
            app:layout_constraintTop_toBottomOf="@id/cardCalendar"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPrestamosDia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvInfoLabel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0"
            tools:listitem="@layout/item_prestamo_lector" />

