<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ivUserDetailAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvUserDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nombre del Socio"
            android:textAlignment="center"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/ivUserDetailAvatar" />

        <TextView
            android:id="@+id/tvUserDetailId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Socio #12345"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tvUserDetailName" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvUserDetailId">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Libros Activos"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserLibrosActivos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 libros" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Multas Pendientes"
                    android:textColor="@android:color/holo_red_dark"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserMultas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrestarLibroUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Prestar libro"
            app:layout_constraintTop_toBottomOf="@id/cardUserStats" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrarDevolucionUser"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Registrar devolución"
            app:layout_constraintTop_toBottomOf="@id/btnPrestarLibroUser" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
