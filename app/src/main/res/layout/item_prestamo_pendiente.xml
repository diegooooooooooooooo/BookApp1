<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvUserInitials"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="CM"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSocioName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Carlos Mendoza"
            android:textColor="@color/header_blue"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/badgeStatusTag"
            app:layout_constraintStart_toEndOf="@id/tvUserInitials"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvLibroPrestado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:drawablePadding="4dp"
            android:text="El Quijote"
            android:textColor="@color/blue_slate"
            android:textSize="13sp"
            app:drawableStartCompat="@android:drawable/ic_menu_agenda"
            app:drawableTint="@color/blue_slate"
            app:layout_constraintEnd_toEndOf="@id/tvSocioName"
            app:layout_constraintStart_toStartOf="@id/tvSocioName"
            app:layout_constraintTop_toBottomOf="@id/tvSocioName" />

        <TextView
            android:id="@+id/tvFechaVencimiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="4dp"
            android:text="Vencimiento: 10/04/2026"
            android:textColor="@color/mora_red"
            android:textSize="11sp"
            app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
            app:drawableTint="@color/mora_red"
            app:layout_constraintStart_toStartOf="@id/tvSocioName"
            app:layout_constraintTop_toBottomOf="@id/tvLibroPrestado" />

        <TextView
            android:id="@+id/badgeStatusTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_red"
            android:backgroundTint="@color/mora_red"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="PENDIENTE"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/badgeRetraso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_red"
            android:drawablePadding="4dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="4 días tarde"
            android:textColor="@color/mora_red"
            android:textSize="10sp"
            app:drawableStartCompat="@android:drawable/stat_notify_error"
            app:drawableTint="@color/mora_red"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>