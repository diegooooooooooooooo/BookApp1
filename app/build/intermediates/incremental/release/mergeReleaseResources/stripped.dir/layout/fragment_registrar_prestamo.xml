<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrar Nuevo Préstamo"
            android:textColor="@color/jet_black"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar Usuario"
            app:boxStrokeColor="@color/blue_slate"
            app:hintTextColor="@color/blue_slate"
            android:textColorHint="@color/silver"
            android:layout_marginBottom="12dp">
            <AutoCompleteTextView
                android:id="@+id/spinnerUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/jet_black"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar Libro"
            app:boxStrokeColor="@color/blue_slate"
            app:hintTextColor="@color/blue_slate"
            android:textColorHint="@color/silver"
            android:layout_marginBottom="12dp">
            <AutoCompleteTextView
                android:id="@+id/spinnerLibro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/jet_black"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha de Devolución"
            app:boxStrokeColor="@color/blue_slate"
            app:hintTextColor="@color/blue_slate"
            android:textColorHint="@color/silver"
            android:layout_marginBottom="24dp"
            app:endIconMode="custom"
            app:endIconTint="@color/blue_slate"
            app:endIconDrawable="@android:drawable/ic_menu_my_calendar">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFechaDevolucion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/jet_black"
                android:focusable="false"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmarPrestamo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Confirmar Préstamo"
            android:backgroundTint="@color/blue_slate"
            android:textColor="@color/white"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
