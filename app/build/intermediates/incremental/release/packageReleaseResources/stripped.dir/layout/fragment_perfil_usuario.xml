<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ivUserDetailAvatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/blue_slate"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvUserDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Nombre del Socio"
            android:textAlignment="center"
            android:textColor="@color/jet_black"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/ivUserDetailAvatar" />

        <TextView
            android:id="@+id/tvUserDetailId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Socio #12345"
            android:textAlignment="center"
            android:textColor="@color/blue_slate"
            app:layout_constraintTop_toBottomOf="@id/tvUserDetailName" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/silver"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/tvUserDetailId">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Libros Activos"
                    android:textColor="@color/blue_slate"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserLibrosActivos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 libros"
                    android:textColor="@color/jet_black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    app:dividerColor="@color/silver" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Multas Pendientes"
                    android:textColor="@color/coral_glow"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserMultas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="@color/jet_black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrestarLibroUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Prestar libro"
            android:padding="12dp"
            android:backgroundTint="@color/blue_slate"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardUserStats" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrarDevolucionUser"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Registrar devolución"
            android:padding="12dp"
            android:textColor="@color/blue_slate"
            app:strokeColor="@color/blue_slate"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnPrestarLibroUser" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
