<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash Screen -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.bookapp.ui.login.SplashFragment"
        android:label="Cargando..."
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Login -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.bookapp.ui.login.LoginFragment"
        android:label="Iniciar Sesión"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_dashboardBibliotecarioFragment"
            app:destination="@id/dashboardBibliotecarioFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_dashboardAdminFragment"
            app:destination="@id/dashboardAdminFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_dashboardLectorFragment"
            app:destination="@id/dashboardLectorFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.example.bookapp.ui.login.SignUpFragment"
        android:label="Crear Cuenta"
        tools:layout="@layout/fragment_sign_up" />

    <!-- FLOW: ADMINISTRADOR -->
    <fragment
        android:id="@+id/dashboardAdminFragment"
        android:name="com.example.bookapp.ui.dashboard.DashboardAdminFragment"
        android:label="Dashboard Admin"
        tools:layout="@layout/fragment_dashboard_admin">
        <action
            android:id="@+id/action_dashboardAdminFragment_to_listaUsuariosFragment"
            app:destination="@id/listaUsuariosFragment" />
        <action
            android:id="@+id/action_dashboardAdminFragment_to_reporteMensualFragment"
            app:destination="@id/reporteMensualFragment" />
        <action
            android:id="@+id/action_dashboardAdminFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
        <action
            android:id="@+id/action_dashboardAdminFragment_to_topLibrosFragment"
            app:destination="@id/topLibrosFragment" />
        <action
            android:id="@+id/action_dashboardAdminFragment_to_listaPendientesFragment"
            app:destination="@id/listaPendientesFragment" />
    </fragment>

    <fragment
        android:id="@+id/listaPendientesFragment"
        android:name="com.example.bookapp.ui.dashboard.ListaPendientesFragment"
        android:label="Pendientes"
        tools:layout="@layout/fragment_lista_pendientes" />

    <fragment
        android:id="@+id/topLibrosFragment"
        android:name="com.example.bookapp.ui.reportes.TopLibrosFragment"
        android:label="Top 5 Libros"
        tools:layout="@layout/fragment_top_libros" />

    <fragment
        android:id="@+id/listaUsuariosFragment"
        android:name="com.example.bookapp.ui.usuarios.ListaUsuariosFragment"
        android:label="Gestión"
        tools:layout="@layout/fragment_lista_usuarios">
        <action
            android:id="@+id/action_listaUsuariosFragment_to_registrarUsuarioFragment"
            app:destination="@id/registrarUsuarioFragment" />
        <action
            android:id="@+id/action_listaUsuariosFragment_to_registrarSocioFragment"
            app:destination="@id/registrarSocioFragment" />
        <action
            android:id="@+id/action_listaUsuariosFragment_to_perfilUsuarioFragment"
            app:destination="@id/perfilUsuarioFragment" />
        <action
            android:id="@+id/action_listaUsuariosFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
    </fragment>

    <fragment
        android:id="@+id/registrarUsuarioFragment"
        android:name="com.example.bookapp.ui.usuarios.RegistrarUsuarioFragment"
        android:label="Nueva Cuenta"
        tools:layout="@layout/fragment_registrar_usuario" />

    <fragment
        android:id="@+id/registrarSocioFragment"
        android:name="com.example.bookapp.ui.usuarios.RegistrarSocioFragment"
        android:label="Nuevo Lector"
        tools:layout="@layout/fragment_registrar_socio" />

    <fragment
        android:id="@+id/perfilUsuarioFragment"
        android:name="com.example.bookapp.ui.usuarios.PerfilUsuarioFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_perfil_usuario" />

    <fragment
        android:id="@+id/reporteMensualFragment"
        android:name="com.example.bookapp.ui.reportes.ReporteMensualFragment"
        android:label="Reporte Mensual"
        tools:layout="@layout/fragment_reporte_mensual">
        <action
            android:id="@+id/action_reporteMensualFragment_to_comparacionMensualFragment"
            app:destination="@id/comparacionMensualFragment" />
        <action
            android:id="@+id/action_reporteMensualFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
    </fragment>

    <fragment
        android:id="@+id/comparacionMensualFragment"
        android:name="com.example.bookapp.ui.reportes.ComparacionMensualFragment"
        android:label="Comparativa"
        tools:layout="@layout/fragment_comparacion_mensual" />


    <!-- FLOW: BIBLIOTECARIO -->
    <fragment
        android:id="@+id/dashboardBibliotecarioFragment"
        android:name="com.example.bookapp.ui.dashboard.DashboardBibliotecarioFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_dashboard_bibliotecario">
        <action
            android:id="@+id/action_dashboardBibliotecarioFragment_to_catalogoLibrosFragment"
            app:destination="@id/catalogoLibrosFragment" />
        <action
            android:id="@+id/action_dashboardBibliotecarioFragment_to_registrarPrestamoFragment"
            app:destination="@id/registrarPrestamoFragment" />
        <action
            android:id="@+id/action_dashboardBibliotecarioFragment_to_registrarDevolucionFragment"
            app:destination="@id/registrarDevolucionFragment" />
        <action
            android:id="@+id/action_dashboardBibliotecarioFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
    </fragment>

    <fragment
        android:id="@+id/catalogoLibrosFragment"
        android:name="com.example.bookapp.ui.libros.CatalogoLibrosFragment"
        android:label="Catálogo"
        tools:layout="@layout/fragment_catalogo_libros">
        <action
            android:id="@+id/action_catalogoLibrosFragment_to_detalleLibroFragment"
            app:destination="@id/detalleLibroFragment" />
        <action
            android:id="@+id/action_catalogoLibrosFragment_to_registrarLibroFragment"
            app:destination="@id/registrarLibroFragment" />
        <action
            android:id="@+id/action_catalogoLibrosFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
    </fragment>

    <fragment
        android:id="@+id/detalleLibroFragment"
        android:name="com.example.bookapp.ui.libros.LibroDetalleFragment"
        android:label="Detalle Libro"
        tools:layout="@layout/fragment_detalle_libro">
        <argument
            android:name="libroId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/registrarLibroFragment"
        android:name="com.example.bookapp.ui.libros.RegistrarLibroFragment"
        android:label="Agregar Libro"
        tools:layout="@layout/fragment_registrar_libro" />

    <fragment
        android:id="@+id/registrarPrestamoFragment"
        android:name="com.example.bookapp.ui.prestamos.RegistrarPrestamoFragment"
        android:label="Nuevo Préstamo"
        tools:layout="@layout/fragment_registrar_prestamo">
        <action
            android:id="@+id/action_registrarPrestamoFragment_to_confirmacionPrestamoFragment"
            app:destination="@id/confirmacionPrestamoFragment" />
        <action
            android:id="@+id/action_registrarPrestamoFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
    </fragment>

    <fragment
        android:id="@+id/confirmacionPrestamoFragment"
        android:name="com.example.bookapp.ui.prestamos.ConfirmacionPrestamoFragment"
        android:label="Ticket"
        tools:layout="@layout/fragment_confirmacion_prestamo" />

    <fragment
        android:id="@+id/registrarDevolucionFragment"
        android:name="com.example.bookapp.ui.prestamos.RegistrarDevolucionFragment"
        android:label="Devolución"
        tools:layout="@layout/fragment_registrar_devolucion" />

    <!-- Pantalla de Configuración -->
    <fragment
        android:id="@+id/configuracionFragment"
        android:name="com.example.bookapp.ui.configuracion.ConfiguracionFragment"
        android:label="Ajustes"
        tools:layout="@layout/fragment_configuracion">
        <action
            android:id="@+id/action_configuracionFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- FLOW: LECTOR (USUARIO COMÚN) -->
    <fragment
        android:id="@+id/dashboardLectorFragment"
        android:name="com.example.bookapp.ui.dashboard.DashboardLectorFragment"
        android:label="Mi Biblioteca"
        tools:layout="@layout/fragment_dashboard_lector">
        <action
            android:id="@+id/action_dashboardLectorFragment_to_catalogoLibrosFragment"
            app:destination="@id/catalogoLibrosFragment" />
        <action
            android:id="@+id/action_dashboardLectorFragment_to_calendarioPrestamosFragment"
            app:destination="@id/calendarioPrestamosFragment" />
        <action
            android:id="@+id/action_dashboardLectorFragment_to_configuracionFragment"
            app:destination="@id/configuracionFragment" />
    </fragment>

    <fragment
        android:id="@+id/calendarioPrestamosFragment"
        android:name="com.example.bookapp.ui.dashboard.CalendarioPrestamosFragment"
        android:label="Calendario"
        tools:layout="@layout/fragment_calendario_prestamos" />

</navigation>
